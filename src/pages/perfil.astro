---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

// 1. LEER LOS TOKENS DESDE LAS COOKIES (Solución al rebote 302)
const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

// Si no hay cookies guardadas, redirigimos inmediatamente al login
if (!accessToken || !refreshToken) {
  return Astro.redirect("/login");
}

// Inicializar de forma segura la sesión en el servidor para esta petición exacta
await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});

// Obtener el usuario autenticado desde la sesión del servidor
const {
  data: { user },
  error: authError,
} = await supabase.auth.getUser();

if (authError || !user) {
  return Astro.redirect("/login");
}

// 2. CAMBIAMOS .single() por .maybeSingle() (Evita el error 406 de objeto JSON)
const { data: profile } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", user.id)
  .maybeSingle();

// 3. Consultar los favoritos reales cruzando con tu tabla 'products'
const { data: favoritesData } = await supabase
  .from("favorites")
  .select(
    `
    product_id,
    products ( id, title, description, price, image_url, category )
  `,
  )
  .eq("user_id", user.id);

// Mapeamos los datos limpios para el HTML
const favoriteGames = favoritesData
  ? favoritesData.map((f) => f.products).filter(Boolean)
  : [];

// 4. Traer el historial de compras oficial vinculando orders, order_items y products (Incluyendo image_url)
const { data: purchaseHistory, error: purchaseError } = await supabase
  .from("orders")
  .select(
    `
    id,
    created_at,
    total,
    status,
    order_items (
      quantity,
      activation_key,
      products (
        title,
        image_url
      )
    )
  `,
  )
  .eq("user_id", user.id)
  .order("created_at", { ascending: false });

if (purchaseError) {
  console.error("Error cargando historial de pedidos:", purchaseError.message);
}
---

<Layout title="Nexus POS | Mi Perfil">
  <nav
    class="border-b border-slate-200 dark:border-slate-800 backdrop-blur-md bg-white/70 dark:bg-slate-950/70 sticky top-0 z-50 transition-colors duration-300"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between"
    >
      <div class="flex items-center gap-2">
        <a
          href="/"
          class="text-2xl font-black tracking-wider bg-gradient-to-r from-violet-600 to-fuchsia-500 bg-clip-text text-transparent hover:opacity-80 transition-all"
        >
          NEXUS_POS
        </a>
      </div>

      <div class="flex items-center gap-4">
        <button
          id="theme-toggle"
          class="p-2 rounded-xl bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 hover:scale-110 active:scale-95 transition-all"
        >
          <span class="dark:hidden">🌙 Modo Noche</span>
          <span class="hidden dark:inline">☀️ Modo Día</span>
        </button>
        <a
          href="/"
          class="text-sm font-bold bg-slate-900 text-white dark:bg-white dark:text-slate-900 px-4 py-2 rounded-xl hover:bg-violet-600 dark:hover:bg-violet-500 dark:hover:text-white transition-all"
        >
          Volver a Tienda 🏪
        </a>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div
      class="flex flex-col md:flex-row items-center gap-6 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-xl mb-8"
    >
      <div class="relative group w-24 h-24">
        <img
          id="avatar-preview"
          class="w-full h-full rounded-full ring-4 ring-violet-500 object-cover shadow-md bg-slate-100 dark:bg-slate-800"
          src={profile?.avatar_url ||
            "https://api.dicebear.com/7.x/pixel-art/svg?seed=Gamer1"}
          alt="User Avatar"
        />
        <label
          for="avatar-file"
          class="absolute inset-0 bg-black/60 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-300"
        >
          <span class="text-white text-xs font-black tracking-wider uppercase"
            >Cambiar</span
          >
        </label>
        <input
          type="file"
          id="avatar-file"
          accept="image/png, image/jpeg, image/webp"
          class="hidden"
        />
      </div>
      <div class="text-center md:text-left">
        <h1
          class="text-3xl font-black tracking-tight text-slate-900 dark:text-white"
        >
          @{profile?.username || user.email?.split("@")[0]}
        </h1>
        <div
          class="flex items-center gap-2 mt-1 justify-center md:justify-start"
        >
          <span class="text-slate-500 dark:text-slate-400 text-sm"
            >Miembro Activo</span
          >
          <span
            class="px-2 py-0.5 text-[10px] font-bold rounded bg-violet-100 dark:bg-violet-950 text-violet-700 dark:text-violet-300 uppercase tracking-wider"
          >
            {profile?.role || "customer"}
          </span>
        </div>
      </div>
    </div>

    <div
      class="flex border-b border-slate-200 dark:border-slate-800 mb-8 gap-2 overflow-x-auto no-scrollbar"
    >
      <button
        data-tab="datos"
        class="tab-btn px-6 py-3 font-bold text-sm border-b-2 border-transparent text-slate-500 dark:text-slate-400 [&.active]:text-violet-600 [&.active]:border-violet-600 transition-all"
      >
        👤 Mis Datos
      </button>
      <button
        data-tab="favoritos"
        class="tab-btn px-6 py-3 font-bold text-sm border-b-2 border-transparent text-slate-500 dark:text-slate-400 [&.active]:text-violet-600 [&.active]:border-violet-600 transition-all"
      >
        ⭐ Mis Favoritos ({favoriteGames.length})
      </button>
      <button
        data-tab="compras"
        class="tab-btn px-6 py-3 font-bold text-sm border-b-2 border-transparent text-slate-500 dark:text-slate-400 [&.active]:text-violet-600 [&.active]:border-violet-600 transition-all"
      >
        📦 Historial de Compras ({purchaseHistory?.length || 0})
      </button>
    </div>

    <div class="relative min-h-[400px]">
      <div id="tab-datos" class="tab-content transition-all duration-300">
        <div
          class="max-w-2xl p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-md"
        >
          <h2 class="text-xl font-bold mb-6">
            Actualizar Información Personal
          </h2>

          <form id="profile-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label
                  class="block text-xs font-bold uppercase text-slate-500 mb-2"
                  >Nombre de Usuario</label
                >
                <input
                  type="text"
                  id="input-username"
                  value={profile?.username || user.email?.split("@")[0]}
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 transition-colors"
                  required
                />
              </div>
              <div>
                <label
                  class="block text-xs font-bold uppercase text-slate-500 mb-2"
                  >Teléfono</label
                >
                <input
                  type="text"
                  id="input-phone"
                  value={profile?.phone || ""}
                  placeholder="No registrado"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 transition-colors"
                />
              </div>
            </div>

            <div>
              <label
                class="block text-xs font-bold uppercase text-slate-500 mb-2"
                >Correo Electrónico (Cuenta de Acceso)</label
              >
              <input
                type="email"
                id="input-email"
                value={user.email}
                class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 transition-colors"
                required
              />
            </div>

            <hr class="border-slate-200 dark:border-slate-800 my-6" />
            <h3
              class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4"
            >
              Seguridad
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label
                  class="block text-xs font-bold uppercase text-slate-500 mb-2"
                  >Nueva Contraseña</label
                >
                <input
                  type="password"
                  id="input-password"
                  placeholder="Mínimo 6 caracteres"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 transition-colors"
                />
              </div>
              <div>
                <label
                  class="block text-xs font-bold uppercase text-slate-500 mb-2"
                  >Confirmar Contraseña</label
                >
                <input
                  type="password"
                  id="input-confirm-password"
                  placeholder="Repite la contraseña"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 transition-colors"
                />
              </div>
            </div>

            <div class="pt-4">
              <button
                type="submit"
                class="w-full sm:w-auto bg-violet-600 hover:bg-violet-700 text-white font-bold px-6 py-3 rounded-xl shadow-md active:scale-95 transition-all"
              >
                Guardar Cambios 💾
              </button>
            </div>
          </form>
        </div>
      </div>

      <div
        id="tab-favoritos"
        class="tab-content hidden transition-all duration-300"
      >
        {
          favoriteGames.length === 0 ? (
            <div class="text-center py-12 border border-dashed border-slate-300 dark:border-slate-700 rounded-2xl">
              <p class="text-slate-500">
                Aún no has añadido ningún juego a tus favoritos. ⭐
              </p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
              {favoriteGames.map((game) => {
                let categoriesArray = [];
                try {
                  categoriesArray =
                    typeof game.category === "string"
                      ? JSON.parse(game.category)
                      : game.category || [];
                } catch (e) {
                  categoriesArray = [game.category];
                }

                return (
                  <div class="game-card group relative rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden shadow-lg transition-all">
                    <div class="relative h-48 overflow-hidden bg-slate-200 dark:bg-slate-800">
                      <img
                        src={game.image_url}
                        alt={game.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                      />
                      <div class="absolute top-3 left-3 flex flex-wrap gap-1 max-w-[80%]">
                        {categoriesArray.map((plat: string) => (
                          <span class="text-[10px] font-black px-2 py-0.5 text-white rounded bg-slate-950/80 backdrop-blur-sm border border-slate-700/50 uppercase tracking-wider">
                            {plat}
                          </span>
                        ))}
                      </div>
                      <button
                        data-remove-fav={game.id}
                        class="remove-fav-btn absolute top-3 right-3 bg-white/90 dark:bg-slate-900/90 p-1.5 rounded-lg text-rose-500 border border-slate-200 dark:border-slate-700 hover:scale-110 active:scale-95 transition-all"
                      >
                        ❤️
                      </button>
                    </div>
                    <div class="p-5">
                      <h3 class="font-bold text-md leading-tight line-clamp-1 group-hover:text-violet-500 transition-colors">
                        {game.title}
                      </h3>
                      <div class="flex items-center justify-between mt-4">
                        <span class="text-xl font-black">${game.price}</span>
                        <button class="bg-slate-900 text-white dark:bg-white dark:text-slate-900 px-4 py-2 rounded-xl text-xs font-bold hover:bg-violet-600 dark:hover:bg-violet-500 dark:hover:text-white transition-all">
                          Añadir ➕
                        </button>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )
        }
      </div>

      <div
        id="tab-compras"
        class="tab-content hidden transition-all duration-300"
      >
        {
          !purchaseHistory || purchaseHistory.length === 0 ? (
            <div class="text-center py-12 border border-dashed border-slate-300 dark:border-slate-700 rounded-2xl">
              <p class="text-slate-500">
                No has realizado ninguna compra todavía. 📦
              </p>
            </div>
          ) : (
            <div class="overflow-x-auto rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-md">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/50">
                    <th class="p-4 font-black text-xs uppercase text-slate-500">
                      ID Ticket
                    </th>
                    <th class="p-4 font-black text-xs uppercase text-slate-500">
                      Fecha
                    </th>
                    <th class="p-4 font-black text-xs uppercase text-slate-500">
                      Productos Comprados / Claves de Activación
                    </th>
                    <th class="p-4 font-black text-xs uppercase text-slate-500 text-right">
                      Total Pagado
                    </th>
                    <th class="p-4 font-black text-xs uppercase text-slate-500 text-center">
                      Estado
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {purchaseHistory.map((ticket) => {
                    const itemsArray = Array.isArray(ticket.order_items)
                      ? ticket.order_items
                      : [];

                    const isCompleted =
                      ticket.status?.toLowerCase() === "completed" ||
                      ticket.status?.toLowerCase() === "paid" ||
                      ticket.status?.toLowerCase() === "pagado" ||
                      ticket.status?.toLowerCase() === "aprobado";

                    const isPending =
                      ticket.status?.toLowerCase() === "pending" ||
                      ticket.status?.toLowerCase() === "pendiente";

                    return (
                      <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-950/30 transition-colors">
                        <td
                          class="p-4 font-mono font-bold text-xs text-violet-500 max-w-[120px] truncate"
                          title={ticket.id}
                        >
                          #{ticket.id.toString().substring(0, 8)}...
                        </td>
                        <td class="p-4 text-sm text-slate-600 dark:text-slate-400 whitespace-nowrap">
                          {new Date(ticket.created_at).toLocaleDateString(
                            "es-MX",
                            {
                              day: "2-digit",
                              month: "short",
                              year: "numeric",
                              hour: "2-digit",
                              minute: "2-digit",
                            },
                          )}
                        </td>
                        <td class="p-4 text-sm">
                          <div class="space-y-2">
                            {itemsArray.map((item: any) => {
                              const game = Array.isArray(item.products)
                                ? item.products[0]
                                : item.products;
                              return (
                                <div class="flex flex-col sm:flex-row sm:items-center gap-3 bg-slate-50 dark:bg-slate-950 p-2 rounded-lg border border-slate-200/60 dark:border-slate-800/60">
                                  {/* 📸 Miniatura del Videojuego */}
                                  <div class="w-12 h-14 rounded-md overflow-hidden bg-slate-200 dark:bg-slate-800 flex-shrink-0 shadow-sm border border-slate-300/40 dark:border-slate-700/40">
                                    <img
                                      src={
                                        game?.image_url ||
                                        "https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=2070"
                                      }
                                      alt={game?.title}
                                      class="w-full h-full object-cover hover:scale-110 transition-transform duration-300"
                                    />
                                  </div>

                                  {/* Título y Llave Digital */}
                                  <div class="flex flex-col gap-1.5 justify-center">
                                    <span class="font-bold text-slate-900 dark:text-white leading-tight">
                                      {game?.title || "Producto"}{" "}
                                      <span class="text-xs text-slate-400 font-normal">
                                        (x{item.quantity})
                                      </span>
                                    </span>
                                    <code
                                      class="text-xs px-2 py-0.5 rounded bg-violet-500/10 text-violet-400 border border-violet-500/20 font-mono tracking-wider select-all w-fit cursor-pointer hover:bg-violet-500/20 transition-all"
                                      title="Haz doble clic para seleccionar el código"
                                    >
                                      🔑{" "}
                                      {item.activation_key || "PROCESANDO_KEY"}
                                    </code>
                                  </div>
                                </div>
                              );
                            })}
                          </div>
                        </td>
                        <td class="p-4 text-sm font-black text-right text-slate-900 dark:text-white whitespace-nowrap">
                          $
                          {Number(ticket.total).toLocaleString("es-MX", {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2,
                          })}
                        </td>
                        <td class="p-4 text-center whitespace-nowrap">
                          {isCompleted ? (
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-emerald-100 text-emerald-800 dark:bg-emerald-950/50 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-900/50">
                              🟢 Entregado
                            </span>
                          ) : isPending ? (
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-amber-100 text-amber-800 dark:bg-amber-950/50 dark:text-amber-400 border border-amber-200 dark:border-amber-900/50">
                              🟡 Pendiente
                            </span>
                          ) : (
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-rose-100 text-rose-800 dark:bg-rose-950/50 dark:text-rose-400 border border-rose-200 dark:border-rose-900/50">
                              🔴 Cancelado
                            </span>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from "../lib/supabase";

  // --- 1. GESTIÓN DE TABS VISTA ---
  const tabButtons = document.querySelectorAll(".tab-btn");
  const tabContents = document.querySelectorAll(".tab-content");
  document.querySelector('[data-tab="datos"]')?.classList.add("active");

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      tabButtons.forEach((btn) => btn.classList.remove("active"));
      button.classList.add("active");

      const targetTab = button.getAttribute("data-tab");
      tabContents.forEach((content) => {
        const htmlContent = content as HTMLElement;
        if (htmlContent.id === `tab-${targetTab}`) {
          htmlContent.classList.remove("hidden");
        } else {
          htmlContent.classList.add("hidden");
        }
      });
    });
  });

  // --- 2. SUBIDA REAL DE ARCHIVOS BINARIOS (AVATAR) ---
  const fileInput = document.getElementById("avatar-file") as HTMLInputElement;
  const avatarPreview = document.getElementById(
    "avatar-preview",
  ) as HTMLImageElement;

  fileInput?.addEventListener("change", async () => {
    const file = fileInput.files?.[0];
    if (!file) return;

    const {
      data: { user },
    } = await supabase.auth.getUser();
    if (!user) return;

    const fileExt = file.name.split(".").pop();
    const filePath = `${user.id}/${Date.now()}.${fileExt}`;

    const { error: uploadError } = await supabase.storage
      .from("avatars")
      .upload(filePath, file, { cacheControl: "3600", upsert: true });

    if (uploadError) {
      alert("Error al subir archivo: " + uploadError.message);
      return;
    }

    const {
      data: { publicUrl },
    } = supabase.storage.from("avatars").getPublicUrl(filePath);

    await supabase
      .from("profiles")
      .upsert({ id: user.id, avatar_url: publicUrl }, { onConflict: "id" });

    avatarPreview.src = publicUrl;
    alert("¡Foto de perfil cargada y sincronizada! 📸");
  });

  // --- 3. ACTUALIZAR CORREO, CONTRASEÑA Y PERFIL ---
  const profileForm = document.getElementById("profile-form");
  profileForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const username = (
      document.getElementById("input-username") as HTMLInputElement
    ).value;
    const phone = (document.getElementById("input-phone") as HTMLInputElement)
      .value;
    const email = (document.getElementById("input-email") as HTMLInputElement)
      .value;
    const password = (
      document.getElementById("input-password") as HTMLInputElement
    ).value;
    const confirmPassword = (
      document.getElementById("input-confirm-password") as HTMLInputElement
    ).value;

    const {
      data: { user },
    } = await supabase.auth.getUser();
    if (!user) return;

    if (password && password !== confirmPassword) {
      alert("❌ Las contraseñas ingresadas no coinciden.");
      return;
    }

    const { error: profileError } = await supabase
      .from("profiles")
      .upsert(
        { id: user.id, username, phone, updated_at: new Date().toISOString() },
        { onConflict: "id" },
      );

    if (profileError) {
      alert("Error al actualizar perfil: " + profileError.message);
      return;
    }

    const updates: any = {};
    if (email !== user.email) updates.email = email;
    if (password) updates.password = password;

    if (Object.keys(updates).length > 0) {
      const { error: authUpdateError } =
        await supabase.auth.updateUser(updates);
      if (authUpdateError) {
        alert("Error de credenciales: " + authUpdateError.message);
        return;
      }
    }

    alert("¡Datos y seguridad guardados correctamente en Supabase! 💾✨");
    window.location.reload();
  });

  // --- 4. ELIMINAR DE FAVORITOS EN VIVO ---
  const removeFavButtons = document.querySelectorAll(".remove-fav-btn");
  removeFavButtons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const productId = btn.getAttribute("data-remove-fav");
      const {
        data: { user },
      } = await supabase.auth.getUser();

      if (!user || !productId) return;

      const { error } = await supabase
        .from("favorites")
        .delete()
        .eq("user_id", user.id)
        .eq("product_id", productId);

      if (!error) {
        btn.closest(".game-card")?.remove();
        alert("Eliminado de tus favoritos. 💔");
      }
    });
  });
</script>
