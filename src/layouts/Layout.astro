---
// src/layouts/Layout.astro

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body
    class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-50 transition-colors duration-300 min-h-screen"
  >
    <div
      class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_50%_120%,rgba(120,119,198,0.1),rgba(255,255,255,0))] dark:bg-[radial-gradient(circle_at_50%_120%,rgba(120,119,198,0.2),rgba(0,0,0,0))] animate-pulse duration-[8000s]"
    >
    </div>

    <slot />

    <script>
      // Lógica básica para el modo oscuro (puedes moverla a un botón después)
      const root = document.documentElement;
      // Aquí añadiremos el script del cursor interactivo en el siguiente paso
    </script>
  </body>
</html>

<style is:global>
  /* Inyección directa de Tailwind v3 sin pasar por PostCSS Import */
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  /* Quita la barra de scroll visual en las categorías */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
