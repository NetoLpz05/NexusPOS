---
// src/components/ChatIA.astro
---

<div class="fixed bottom-6 right-6 z-[9999] font-sans">
  <button
    id="nexus-bot-toggle"
    class="w-14 h-14 bg-gradient-to-tr from-violet-600 to-fuchsia-500 rounded-full flex items-center justify-center text-white shadow-2xl hover:scale-110 active:scale-95 hover:rotate-12 transition-all duration-300 group relative"
    aria-label="Abrir Asistente Nexus AI"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      class="w-6 h-6 transition-transform duration-300 group-[.active]:scale-0 group-[.active]:absolute"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.222 3.419.169l2.806 2.805c.452.452 1.233.132 1.233-.503V16.5m-.002-13.187A17.886 17.886 0 0 0 12 3c-1.283 0-2.53.134-3.736.392m12.393 2.842a17.47 17.47 0 0 1-1.333 4.5c-.21.514-.648.86-1.154.996A46.245 46.245 0 0 0 12 12.75c-1.123 0-2.223-.083-3.302-.242a1.442 1.442 0 0 1-1.154-.996 17.47 17.47 0 0 1-1.333-4.5m12.393 2.842a17.47 17.47 0 0 0-1.333-4.5M3.939 5.684A17.47 17.47 0 0 1 5.272 1.184m0 0a1.442 1.442 0 0 1 1.154.996C6.912 3.125 7.375 4.14 7.641 5.2"
      ></path>
    </svg>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      class="w-6 h-6 scale-0 absolute transition-transform duration-300 group-[.active]:scale-100"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6 18 18 6M6 6l12 12"></path>
    </svg>
    <span class="absolute -top-1 -right-1 flex h-3 w-3 group-[.active]:hidden">
      <span
        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-fuchsia-400 opacity-75"
      ></span>
      <span class="relative inline-flex rounded-full h-3 w-3 bg-fuchsia-500"
      ></span>
    </span>
  </button>

  <div
    id="nexus-bot-window"
    class="hidden opacity-0 scale-95 translate-y-4 fixed bottom-24 right-6 w-[90vw] sm:w-[380px] h-[500px] bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl flex flex-col overflow-hidden transition-all duration-300"
  >
    <div
      class="p-4 bg-gradient-to-r from-violet-600 to-fuchsia-500 text-white flex items-center justify-between shadow-md"
    >
      <div class="flex items-center gap-2.5">
        <div
          class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-lg shadow-inner"
        >
          🤖
        </div>
        <div>
          <h3 class="font-black text-sm tracking-wide leading-tight">
            NEXUS AI
          </h3>
          <span
            class="text-[10px] text-violet-100 flex items-center gap-1 font-medium"
          >
            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"
            ></span> En línea para ayudarte
          </span>
        </div>
      </div>
    </div>

    <div
      id="nexus-bot-messages"
      class="flex-1 p-4 overflow-y-auto space-y-3 scrollbar-thin scrollbar-thumb-slate-200 dark:scrollbar-thumb-slate-800 bg-slate-50/50 dark:bg-slate-950/20"
    >
      <div class="flex items-start gap-2 max-w-[85%]">
        <div
          class="w-6 h-6 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center text-xs flex-shrink-0 shadow-sm"
        >
          🤖
        </div>
        <div
          class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700/60 text-slate-800 dark:text-slate-200 text-xs px-3 py-2.5 rounded-2xl rounded-tl-none shadow-sm leading-relaxed"
        >
          ¡Hola! 👋 Bienvenido a **Nexus POS**. ¿Tienes alguna duda sobre
          juegos, keys de activación o soporte técnico? ¡Pregúntame lo que
          necesites!
        </div>
      </div>
    </div>

    <form
      id="nexus-bot-form"
      class="p-3 border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex gap-2 items-center"
    >
      <input
        type="text"
        id="nexus-bot-input"
        placeholder="Escribe tu mensaje aquí..."
        maxlength="300"
        class="flex-1 px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all placeholder:text-slate-400"
        required
        autocomplete="off"
      />
      <button
        type="submit"
        class="bg-violet-600 hover:bg-violet-700 text-white p-2.5 rounded-xl shadow-md active:scale-95 transition-all flex items-center justify-center flex-shrink-0"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4 rotate-45 -translate-px -translate-y-px"
        >
          <path
            d="M3.478 2.404a.75.75 0 0 0-.926.941l2.432 7.905H13.5a.75.75 0 0 1 0 1.5H4.984l-2.432 7.905a.75.75 0 0 0 .926.94 60.519 60.519 0 0 0 18.445-8.986.75.75 0 0 0 0-1.218A60.517 60.517 0 0 0 3.478 2.404Z"
          ></path>
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  function initChatbot() {
    const botToggle = document.getElementById("nexus-bot-toggle");
    const botWindow = document.getElementById("nexus-bot-window");
    const botForm = document.getElementById(
      "nexus-bot-form",
    ) as HTMLFormElement;
    const botInput = document.getElementById(
      "nexus-bot-input",
    ) as HTMLInputElement;
    const botMessages = document.getElementById("nexus-bot-messages");

    if (!botToggle || !botWindow) return;

    botToggle.addEventListener("click", () => {
      botToggle.classList.toggle("active");
      if (botWindow.classList.contains("hidden")) {
        botWindow.classList.remove("hidden");
        setTimeout(() => {
          botWindow.classList.remove("opacity-0", "scale-95", "translate-y-4");
          scrollToBottom();
        }, 10);
      } else {
        botWindow.classList.add("opacity-0", "scale-95", "translate-y-4");
        setTimeout(() => botWindow.classList.add("hidden"), 300);
      }
    });

    function scrollToBottom() {
      if (botMessages) botMessages.scrollTop = botMessages.scrollHeight;
    }

    botForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const userText = botInput.value.trim();
      if (!userText) return;

      botInput.value = "";
      appendMessage(userText, "user");
      scrollToBottom();

      const typingId = appendTypingIndicator();
      scrollToBottom();

      try {
        // Redirección corregida al puerto 8000 de tu Backend de Python
        const response = await fetch("http://localhost:8000/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message: userText }),
        });

        const data = await response.json();
        removeTypingIndicator(typingId);

        if (response.ok && data.response) {
          // Captura de la respuesta inyectada con las instrucciones de tu backend
          appendMessage(data.response, "bot");
        } else {
          const errorMsg = data.detail || "Error interno del servidor.";
          appendMessage(`❌ **Error**: ${errorMsg}`, "bot");
        }
      } catch (error) {
        removeTypingIndicator(typingId);
        console.error("Error al conectar con el backend:", error);
        appendMessage(
          "❌ **Error de comunicación**: No se pudo conectar con el backend de Python. Asegúrate de que Uvicorn esté corriendo en el puerto 8000.",
          "bot",
        );
      }
      scrollToBottom();
    });

    function appendMessage(text: string, sender: "user" | "bot") {
      if (!botMessages) return;
      const messageDiv = document.createElement("div");
      messageDiv.className =
        sender === "user"
          ? "flex items-start gap-2 justify-end max-w-[85%] ml-auto"
          : "flex items-start gap-2 max-w-[85%]";

      const formattedText = text
        .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
        .replace(
          /`(.*?)`/g,
          '<code class="bg-slate-100 dark:bg-slate-800 px-1 py-0.5 rounded text-fuchsia-500 font-mono text-[11px]">$1</code>',
        );

      messageDiv.innerHTML =
        sender === "user"
          ? `<div class="bg-gradient-to-tr from-violet-600 to-fuchsia-500 text-white text-xs px-3 py-2.5 rounded-2xl rounded-tr-none shadow-sm leading-relaxed">${formattedText}</div>`
          : `<div class="w-6 h-6 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center text-xs flex-shrink-0 shadow-sm">🤖</div>
             <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700/60 text-slate-800 dark:text-slate-200 text-xs px-3 py-2.5 rounded-2xl rounded-tl-none shadow-sm leading-relaxed">${formattedText}</div>`;
      botMessages.appendChild(messageDiv);
    }

    function appendTypingIndicator() {
      const id = "typing-" + Date.now();
      const indicator = document.createElement("div");
      indicator.id = id;
      indicator.className = "flex items-start gap-2 max-w-[85%]";
      indicator.innerHTML = `
        <div class="w-6 h-6 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center text-xs flex-shrink-0">🤖</div>
        <div class="bg-slate-200/60 dark:bg-slate-800/60 text-slate-500 text-xs px-3 py-2 rounded-xl flex items-center gap-1">
          <span class="w-1.5 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
          <span class="w-1.5 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
          <span class="w-1.5 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
        </div>`;
      botMessages?.appendChild(indicator);
      return id;
    }

    function removeTypingIndicator(id: string) {
      document.getElementById(id)?.remove();
    }
  }

  document.addEventListener("astro:page-load", initChatbot);
</script>
