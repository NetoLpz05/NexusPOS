<nav
  class="border-b border-slate-200 dark:border-slate-800 backdrop-blur-md bg-white/70 dark:bg-slate-950/70 sticky top-0 z-50 transition-colors duration-300"
>
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between"
  >
    <div class="flex items-center gap-2">
      <a
        href="/"
        class="text-2xl font-black tracking-wider bg-gradient-to-r from-violet-600 to-fuchsia-500 bg-clip-text text-transparent"
      >
        NEXUS_POS
      </a>
    </div>

    <div class="flex items-center gap-4">
      <button
        id="theme-toggle-nav"
        class="p-2 rounded-xl bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 hover:scale-110 active:scale-95 transition-all"
      >
        <span class="dark:hidden">🌙</span>
        <span class="hidden dark:inline">☀️</span>
      </button>

      <a
        href="/carrito"
        id="cart-nav-btn"
        class="relative p-2 rounded-xl bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 cursor-pointer text-slate-700 dark:text-slate-300 hover:scale-110 active:scale-95 transition-all block"
        title="Ver mi carrito de compras"
      >
        🛒 <span
          id="cart-count"
          class="absolute -top-1 -right-1 bg-fuchsia-600 text-white text-[10px] font-black w-5 h-5 flex items-center justify-center rounded-full scale-0 transition-transform duration-300"
          >0</span
        >
      </a>

      <div
        id="auth-nav-container"
        class="flex items-center gap-3 border-l pl-4 border-slate-200 dark:border-slate-800"
      >
        {/* Esqueleto de carga inicial */}
        <div
          class="w-20 h-8 bg-slate-200 dark:bg-slate-800 rounded-full animate-pulse"
        >
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  // ⚡ Importación directa integrada en el empaquetado de Astro
  import { supabase } from "../../lib/supabase";

  // 🔄 Función para actualizar el contador físico de videojuegos en el carrito
  async function updateCartCount(userId) {
    const cartCount = document.getElementById("cart-count");
    if (!cartCount) return;

    try {
      // Hacemos un conteo exacto y eficiente apuntando a la tabla filtrada por usuario
      const { count, error } = await supabase
        .from("cart_items")
        .select("id", { count: "exact", head: true })
        .eq("user_id", userId);

      if (error) throw error;

      if (count && count > 0) {
        cartCount.textContent = count.toString();
        cartCount.classList.remove("scale-0");
        cartCount.classList.add("scale-100", "animate-bounce");
        // Quitamos el rebote después de 1 segundo para mantener la UI limpia
        setTimeout(() => cartCount.classList.remove("animate-bounce"), 1000);
      } else {
        cartCount.textContent = "0";
        cartCount.classList.remove("scale-100");
        cartCount.classList.add("scale-0");
      }
    } catch (err) {
      console.error("❌ Error actualizando contador de carrito:", err);
    }
  }

  async function initNavbar() {
    const container = document.getElementById("auth-nav-container");
    const cartCount = document.getElementById("cart-count");
    if (!container) return;

    console.log("🔍 Navbar: Comprobando sesión activa...");

    try {
      const {
        data: { user },
        error: authError,
      } = await supabase.auth.getUser();

      if (authError) {
        console.error("❌ Error en Auth:", authError.message);
      }

      if (user) {
        console.log("👤 Usuario devuelto por Supabase:", user.id);

        // Disparar la actualización del carrito al detectar sesión
        updateCartCount(user.id);

        const { data: profile, error: profileError } = await supabase
          .from("profiles")
          .select("*")
          .eq("id", user.id)
          .maybeSingle();

        if (profileError) {
          console.error("❌ Error en Tabla Profiles:", profileError.message);
        }

        const avatarUrl =
          profile?.avatar_url ||
          "https://api.dicebear.com/7.x/pixel-art/svg?seed=Gamer1";

        const username =
          profile?.username || user.email?.split("@")[0] || "User";

        // Inyectamos el botón de perfil y el botón de cerrar sesión juntos
        container.innerHTML = `
          <div id="btn-nav-perfil" class="flex items-center gap-3 pl-2 pr-4 py-1.5 rounded-full border border-transparent hover:border-slate-200 dark:hover:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-900/50 active:scale-95 transition-all cursor-pointer group" title="Ir a mi perfil">
            <div class="relative w-9 h-9">
              <img class="w-full h-full rounded-full ring-2 ring-violet-500 object-cover shadow-sm group-hover:ring-fuchsia-500 transition-all duration-300" src="${avatarUrl}" alt="Avatar" />
            </div>
            <span class="text-sm font-bold text-slate-700 dark:text-slate-300 group-hover:text-violet-500 transition-colors duration-200">
              @${username}
            </span>
          </div>

          <button
            id="logout-nav-btn"
            class="bg-rose-500/10 hover:bg-rose-500 text-rose-500 hover:text-white border border-rose-500/20 p-2 rounded-xl transition-all flex items-center justify-center active:scale-95 gap-1 text-xs font-bold"
            title="Cerrar Sesión"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
            </svg>
            Cerrar Sesión
          </button>
        `;

        // Escuchador de clic para ir al perfil
        const botonPerfil = document.getElementById("btn-nav-perfil");
        botonPerfil?.addEventListener("click", () => {
          console.log("🚀 Navegando a /perfil...");
          window.location.href = "/perfil";
        });

        // Escuchador de clic para cerrar sesión limpiamente
        const botonLogout = document.getElementById("logout-nav-btn");
        botonLogout?.addEventListener("click", async () => {
          console.log("🔒 Cerrando sesión y destruyendo cookies...");

          await supabase.auth.signOut();

          document.cookie =
            "sb-access-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax; Secure";
          document.cookie =
            "sb-refresh-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax; Secure";

          window.location.href = "/login";
        });
      } else {
        console.log("⏹️ No hay usuario activo. Mostrando botón.");
        container.innerHTML = `
          <a href="/login" class="text-xs font-bold bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white px-4 py-2 rounded-xl hover:opacity-90 active:scale-95 transition-all shadow-md shadow-violet-500/10">
            Ingresar 🎮
          </a>
        `;
        // Ocultar contador de carrito si no hay sesión
        if (cartCount) cartCount.classList.add("scale-0");
      }
    } catch (err) {
      console.error("❌ Error crítico en el hilo del Navbar:", err);
    }
  }

  // 🔥 Ejecuta el script de autenticación cada vez que se carga una nueva pantalla en la SPA
  document.addEventListener("astro:page-load", () => {
    initNavbar();
  });
</script>
